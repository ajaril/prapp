{
   "action": {
      "default_icon": "logocalifica.png",
      "default_popup": "popup.html",
      "default_title": "Criteriapp"
   },
   "icons": {
      "128": "logocalifica.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "open-udemy": {
         "description": "Activa algunas funciones de prueba",
         "suggested_key": {
            "default": "Ctrl+Shift+U",
            "mac": "Command+Shift+U"
         }
      }
   },
   "content_scripts": [ {
      "css": [ "content.css" ],
      "js": [ "content.js" ],
      "matches": [ "https://seneca.juntadeandalucia.es/seneca/*" ],
      "run_at": "document_start"
   } ],
   "description": "Criteriapp — gestión de calificaciones para Séneca",
   "manifest_version": 3,
   "name": "Criteriapp",
   "permissions": [ "storage" ],
   "version": "0.1.0"
}
